---
import { Tabs, TabItem } from "@astrojs/starlight/components";
import { data } from "src/javascript/downloadsData";
---

<div class="max-w-184 mx-auto pb-20" id="downloads">
  <Tabs>
    {
      data.map((platform) => (
        <TabItem label={platform.title}>
          <article class="card sl-flex w-full">
            <p class="title sl-flex">
              <img
                src={platform.image}
                alt={platform.title}
                class="h-10 w-10"
              />

              <span set:html={platform.title} />
            </p>
            <div class="body">{platform.description}</div>
            {platform.hashes ? (
              <Tabs>
                {Object.keys(platform.hashes).map((hashType) => (
                  <TabItem label={hashType}>
                    <p class="w-full" />

                    <div class="max-w-full mx-auto">
                      <div class="rounded-md p-4 relative border border-gray-300 dark:border-[#2B2E3D]">
                        <p class="text-sm font-mono block mb-8">
                          <code
                            id="code-block"
                            style="background: transparent; padding: 0;"
                          >
                            {/*  @ts-expect-error */}
                            {platform.hashes[hashType]}
                          </code>
                        </p>
                        {/*  @ts-expect-error */}
                        <button
                          onclick={`copyToClipboard(event, '${platform.hashes[hashType]}')`}
                          class="copy-btn absolute bottom-2 right-1/2 translate-x-1/2 text-xs px-3 py-1.5 rounded cursor-pointer"
                        >
                          Copy
                        </button>
                      </div>
                    </div>
                  </TabItem>
                ))}
              </Tabs>
            ) : null}

            <a
              href={platform.downloadURL}
              class="download-btn mt-8 inline-flex items-center gap-x-2 rounded-md px-3.5 py-2.5 text-sm font-semibold shadow-sm w-fit no-underline"
              id={`download-${platform.id}`}
            >
              {platform.buttonLabel}
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="currentColor"
                class="size-6 -mr-0.5"
              >
                <path
                  fill-rule="evenodd"
                  d="M12 2.25c-5.385 0-9.75 4.365-9.75 9.75s4.365 9.75 9.75 9.75 9.75-4.365 9.75-9.75S17.385 2.25 12 2.25Zm-.53 14.03a.75.75 0 0 0 1.06 0l3-3a.75.75 0 1 0-1.06-1.06l-1.72 1.72V8.25a.75.75 0 0 0-1.5 0v5.69l-1.72-1.72a.75.75 0 0 0-1.06 1.06l3 3Z"
                  clip-rule="evenodd"
                />
              </svg>
            </a>
            {platform.enableDownloadCounter && (
              <p class="text-xs italic" id={`count-${platform.id}`} />
            )}
          </article>
        </TabItem>
      ))
    }
  </Tabs>
</div>

<script is:inline>
  function copyToClipboard(event, text) {
    navigator.clipboard.writeText(text);
    event.target.innerText = "Copied!";
    setTimeout(() => {
      event.target.innerText = "Copy";
    }, 2000);
  }
</script>

<script>
  import { actions } from "astro:actions";

  async function increaseCount(id: string) {
    await actions.increaseCount({ id });
  }

  document.addEventListener("DOMContentLoaded", async () => {
    const { data, error } = await actions.getDownloadCount();

    if (!error) {
      data.forEach(
        (element: { download_type: string; download_count: string }) => {
          let countElement = document.getElementById(
            "count-" + element.download_type,
          );
          if (countElement)
            countElement.innerHTML = `Downloaded ${element.download_count} times`;
        },
      );

      data.forEach(
        (element: { download_type: string; download_count: string }) => {
          const button = document.getElementById(
            `download-` + element.download_type,
          );
          let isRequestInProgress = false;
          button?.addEventListener("click", function (e) {
            e.preventDefault();
            if (isRequestInProgress) {
              return;
            }
            isRequestInProgress = true;

            try {
              increaseCount(element.download_type);
              console.log("it ran");
              setTimeout(() => {
                // @ts-expect-error
                window.location.href = button.getAttribute("href");
              }, 1000);
            } catch (e) {
              console.log(e);
            } finally {
              setTimeout(() => {
                isRequestInProgress = false;
              }, 3000);
            }
          });
        },
      );
    }
  });
</script>

<style>
  ul {
    align-items: center !important;
    justify-content: center !important;
  }

  .card {
    --sl-card-border: var(--sl-color-purple);
    --sl-card-bg: var(--sl-color-purple-low);
    border: 1px solid var(--sl-color-gray-5);
    background-color: var(--sl-color-black);
    padding: clamp(1rem, calc(0.125rem + 3vw), 2.5rem);
    flex-direction: column;
    gap: clamp(0.5rem, calc(0.125rem + 1vw), 1rem);
  }
  :global([data-theme="dark"]) .card {
    background-color: #131628;
    border-color: #2b2e3d;
  }
  .card:nth-child(4n + 1) {
    --sl-card-border: var(--sl-color-orange);
    --sl-card-bg: var(--sl-color-orange-low);
  }
  .card:nth-child(4n + 3) {
    --sl-card-border: var(--sl-color-green);
    --sl-card-bg: var(--sl-color-green-low);
  }
  .card:nth-child(4n + 4) {
    --sl-card-border: var(--sl-color-red);
    --sl-card-bg: var(--sl-color-red-low);
  }
  .card:nth-child(4n + 5) {
    --sl-card-border: var(--sl-color-blue);
    --sl-card-bg: var(--sl-color-blue-low);
  }
  .title {
    font-weight: 600;
    font-size: var(--sl-text-h4);
    color: var(--sl-color-white);
    line-height: var(--sl-line-height-headings);
    gap: 1rem;
    align-items: center;
  }
  .card .icon {
    border: 1px solid var(--sl-card-border);
    background-color: var(--sl-card-bg);
    padding: 0.2em;
    border-radius: 0.25rem;
  }
  .card .body {
    margin: 0;
    font-size: clamp(
      var(--sl-text-sm),
      calc(0.5rem + 1vw),
      var(--sl-text-body)
    );
  }

  .copy-btn {
    background: var(--sl-color-text-accent);
    color: var(--sl-color-bg);
    font-weight: 600;
    transition: opacity 0.2s;
  }
  .copy-btn:hover {
    opacity: 0.85;
  }

  .download-btn {
    background: var(--sl-color-text-accent);
    color: var(--sl-color-bg);
    font-weight: 700;
    transition:
      opacity 0.2s,
      transform 0.2s;
  }
  .download-btn:hover {
    opacity: 0.88;
    transform: translateY(-1px);
  }

  starlight-tab-item {
    display: none !important;
  }
</style>
